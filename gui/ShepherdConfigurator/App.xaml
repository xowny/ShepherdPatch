<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ShepherdConfigurator.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ShepherdConfigurator">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="HomecomingBackgroundColor">#FF070505</Color>
            <Color x:Key="HomecomingShellColor">#FF0F0D0C</Color>
            <Color x:Key="HomecomingRailColor">#FF13110F</Color>
            <Color x:Key="HomecomingHeaderColor">#FF151311</Color>
            <Color x:Key="HomecomingSurfaceColor">#FF191613</Color>
            <Color x:Key="HomecomingSurfaceInsetColor">#FF100D0B</Color>
            <Color x:Key="HomecomingSurfaceBorderColor">#FF302823</Color>
            <Color x:Key="HomecomingSurfaceBorderStrongColor">#FF4A3A30</Color>
            <Color x:Key="HomecomingAccentColor">#FFB95A25</Color>
            <Color x:Key="HomecomingAccentStrongColor">#FFD87A38</Color>
            <Color x:Key="HomecomingTextColor">#FFF2E9DB</Color>
            <Color x:Key="HomecomingMutedTextColor">#FFC9B59A</Color>
            <Color x:Key="HomecomingDimTextColor">#FF8C735B</Color>

            <SolidColorBrush x:Key="HomecomingBackgroundBrush" Color="{StaticResource HomecomingBackgroundColor}" />
            <SolidColorBrush x:Key="HomecomingShellBrush" Color="{StaticResource HomecomingShellColor}" />
            <SolidColorBrush x:Key="HomecomingRailBrush" Color="{StaticResource HomecomingRailColor}" />
            <SolidColorBrush x:Key="HomecomingHeaderBrush" Color="{StaticResource HomecomingHeaderColor}" />
            <SolidColorBrush x:Key="HomecomingSurfaceBrush" Color="{StaticResource HomecomingSurfaceColor}" />
            <SolidColorBrush x:Key="HomecomingSurfaceInsetBrush" Color="{StaticResource HomecomingSurfaceInsetColor}" />
            <SolidColorBrush x:Key="HomecomingSurfaceBorderBrush" Color="{StaticResource HomecomingSurfaceBorderColor}" />
            <SolidColorBrush x:Key="HomecomingSurfaceBorderStrongBrush" Color="{StaticResource HomecomingSurfaceBorderStrongColor}" />
            <SolidColorBrush x:Key="HomecomingAccentBrush" Color="{StaticResource HomecomingAccentColor}" />
            <SolidColorBrush x:Key="HomecomingAccentStrongBrush" Color="{StaticResource HomecomingAccentStrongColor}" />
            <SolidColorBrush x:Key="HomecomingTextBrush" Color="{StaticResource HomecomingTextColor}" />
            <SolidColorBrush x:Key="HomecomingMutedTextBrush" Color="{StaticResource HomecomingMutedTextColor}" />
            <SolidColorBrush x:Key="HomecomingDimTextBrush" Color="{StaticResource HomecomingDimTextColor}" />

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource HomecomingTextBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="RailKickerTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource HomecomingDimTextBrush}" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="CharacterSpacing" Value="28" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
            </Style>

            <Style x:Key="RailTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="RailMetaTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource HomecomingMutedTextBrush}" />
                <Setter Property="FontSize" Value="11.5" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="HeaderTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontSize" Value="19" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="SectionCaptionTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource HomecomingDimTextBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>

            <Style x:Key="StatusTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource HomecomingMutedTextBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="SettingLabelTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource HomecomingTextBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>

            <Style x:Key="SettingDescriptionTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource HomecomingMutedTextBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Margin" Value="0,3,0,0" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
                <Setter Property="TextTrimming" Value="None" />
                <Setter Property="LineHeight" Value="17" />
            </Style>

            <Style x:Key="HomecomingButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource HomecomingSurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource HomecomingTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource HomecomingSurfaceBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="11,7" />
                <Setter Property="MinHeight" Value="32" />
            </Style>

            <Style x:Key="HomecomingAccentButtonStyle" TargetType="Button" BasedOn="{StaticResource HomecomingButtonStyle}">
                <Setter Property="Background" Value="{StaticResource HomecomingAccentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource HomecomingAccentStrongBrush}" />
            </Style>

            <Style x:Key="HomecomingSidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource HomecomingButtonStyle}">
                <Setter Property="Padding" Value="10,9" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
            </Style>

            <Style x:Key="HomecomingTopNavButtonStyle" TargetType="Button" BasedOn="{StaticResource HomecomingButtonStyle}">
                <Setter Property="Padding" Value="11,6" />
                <Setter Property="MinWidth" Value="82" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
            </Style>

            <Style x:Key="HomecomingTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource HomecomingSurfaceInsetBrush}" />
                <Setter Property="Foreground" Value="{StaticResource HomecomingTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource HomecomingSurfaceBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="10,7" />
            </Style>

            <Style TargetType="NumberBox">
                <Setter Property="Background" Value="{StaticResource HomecomingSurfaceInsetBrush}" />
                <Setter Property="Foreground" Value="{StaticResource HomecomingTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource HomecomingSurfaceBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="MinWidth" Value="0" />
            </Style>

            <Style x:Key="HomecomingCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource HomecomingTextBrush}" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style x:Key="SettingsPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource HomecomingSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource HomecomingSurfaceBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="11" />
            </Style>

            <Style x:Key="SectionHeaderGridStyle" TargetType="Grid">
                <Setter Property="Margin" Value="0,0,0,5" />
            </Style>

            <Style x:Key="SettingRowGridStyle" TargetType="Grid">
                <Setter Property="BorderBrush" Value="{StaticResource HomecomingSurfaceBorderBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="Padding" Value="0,6,0,6" />
            </Style>

            <Style x:Key="ValuesGridStyle" TargetType="Grid">
                <Setter Property="Margin" Value="0,8,0,0" />
            </Style>

            <Style x:Key="ValueDescriptionTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource HomecomingDimTextBrush}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Margin" Value="0,3,0,0" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
                <Setter Property="TextTrimming" Value="None" />
                <Setter Property="LineHeight" Value="15" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
